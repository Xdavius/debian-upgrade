import { Button, CheckBox, ScrollView } from "std-widgets.slint";

export struct ThirdPartyRepo {
    name: string,
    enabled: bool,
}

export component AppWindow inherits Window {
    in-out property <int> current_page: 1;
    in-out property <string> header_status: "Assistant pret";
    in-out property <color> header_status_color: #4f5b66;
    in-out property <string> logs_text: "[info] Demarrage de l'assistant.\n\n";
    in-out property <bool> action_in_progress: false;
    out property <bool> logs_has_focus: false;

    in-out property <[ThirdPartyRepo]> third_party_repos;

    callback go_next();
    callback go_prev();
    callback validate_sources();
    callback run_dkms_step();
    callback check_new_release();
    callback run_download_step();
    callback run_dry_run_upgrade();
    callback request_reboot();
    callback close_app();
    callback set_third_party_enabled(int, bool);
    public function scroll_logs_to_end(offset: int) {
        logs-scroll.viewport-y = min(0px, logs-scroll.visible-height - logs-scroll.viewport-height);
    }

    width: 960px;
    height: 740px;
    title: "Debian Upgrade Assistant";
    default-font-size: 12px;

    Rectangle {
        background: #f2f3f5;

        VerticalLayout {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            spacing: 12px;
            padding: 16px;

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 64px;

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "Debian Upgrade Assistant";
                        font-size: 20px;
                        color: #1b1e23;
                        vertical-alignment: center;
                    }

                    Rectangle { }
                }

                Rectangle {
                    x: parent.width - self.width - 14px;
                    y: 0px;
                    width: 250px;
                    height: parent.height;
                    background: transparent;
                    Rectangle {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: parent.height;
                        background: transparent;
                        clip: true;
                        Text {
                            x: 0px;
                            y: (parent.height - self.height) / 2;
                            width: parent.width - 4px;
                            text: root.header_status;
                            font-size: 12px;
                            color: root.header_status_color;
                            horizontal-alignment: right;
                            overflow: elide;
                        }
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 320px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;

                    Text {
                        text: root.current_page == 1 ? "Bienvenue" :
                              root.current_page == 2 ? "Sources APT et depots tiers" :
                              root.current_page == 3 ? "Pilotes DKMS" :
                              root.current_page == 4 ? "Preparation des paquets" :
                              root.current_page == 5 ? "Test de mise a niveau (dry-run)" :
                              root.current_page == 6 ? "Mise a niveau finale" :
                              "Aucune mise a niveau disponible";
                        font-size: 22px;
                        color: #1b1e23;
                        vertical-stretch: 0;
                    }

                    Text {
                        text: root.current_page == 1
                            ? "Cet assistant vous guide pour preparer une mise a niveau majeure Debian de maniere controlee.\nVous allez verifier les sources APT, gerer les depots tiers, preparer les paquets, tester la procedure puis finaliser au redemarrage.\nIl est fortement recommande d'avoir mis a jour votre systeme et d'avoir redemarre avant de continuer la procedure.\nLorsque vous cliquerez sur Suivant, votre systeme commencera a etre modifie et les sources de la distribution seront modifiees."
                            : root.current_page == 2                        
                            ? "Par securite, tous les depots tiers sont desactives par defaut. Vous pouvez les re-activer manuellement si necessaire."
                            : root.current_page == 3
                            ? "Cette etape prepare les modules DKMS (ex: NVIDIA) pour limiter les risques pendant la mise a niveau du kernel."
                            : root.current_page == 4
                            ? "Cette etape va nettoyer le cache APT et telecharger les paquets necessaires. Cliquez sur Suivant pour declencher."
                            : root.current_page == 5
                            ? "Un test de mise a niveau va etre execute en mode simulation pour verifier le deroulement."
                            : root.current_page == 6
                            ? "En cliquant sur Redemarrer, le PC redemarrera et la mise a niveau hors-ligne sera effectuee."
                            : "Le processus s'arrete ici: aucune nouvelle version majeure Debian n'est disponible pour ce systeme.";
                        wrap: word-wrap;
                        font-size: 14px;
                        color: #2f3a45;
                        vertical-stretch: 0;
                    }

                    Rectangle {
                        visible: root.current_page == 2;
                        background: #f8f9fb;
                        border-color: #e3e7ee;
                        border-width: 1px;
                        border-radius: 6px;
                        padding: 10px;
                        vertical-stretch: 1;
                        ScrollView {
                            VerticalLayout {
                                spacing: 6px;
                                for repo[index] in root.third_party_repos: CheckBox {
                                    text: "Depot tiers: " + repo.name;
                                    checked: repo.enabled;
                                    vertical-stretch: 0;
                                    toggled => {
                                        root.set_third_party_enabled(index, self.checked);
                                    }
                                }
                            }
                        }
                    }

                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 200px;

                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;

                    Text {
                        text: "Logs";
                        font-size: 18px;
                        color: #1b1e23;
                    }

                    logs-scroll := ScrollView {
                        vertical-stretch: 1;
                        viewport-width: logs-scroll.visible-width;
                        viewport-height: logs-content.preferred-height + 8px;
                        Rectangle {
                            width: logs-scroll.visible-width;
                            height: logs-content.preferred-height + 8px;
                            logs-content := Text {
                                x: 0px;
                                width: logs-scroll.visible-width;
                                text: root.logs_text;
                                font-size: 14px;
                                wrap: word-wrap;
                                color: #2f3a45;
                                horizontal-alignment: left;
                                vertical-alignment: top;
                            }
                        }
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 82px;

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Rectangle {
                        width: 140px;
                        background: transparent;
                        Button {
                            x: 0px;
                            y: (parent.height - self.height) / 2;
                            width: 124px;
                            height: 40px;
                            text: "Precedent";
                        enabled: root.current_page > 1 && root.current_page < 7 && !root.action_in_progress;
                            clicked => { root.go_prev(); }
                        }
                    }

                    Rectangle { horizontal-stretch: 1; background: transparent; }

                    VerticalLayout {
                        spacing: 0px;
                        Rectangle { vertical-stretch: 1; background: transparent; }
                        HorizontalLayout {
                            spacing: 8px;

                            for step[i] in [1, 2, 3, 4, 5, 6]: HorizontalLayout {
                                spacing: 6px;

                                Text {
                                    visible: step > 1;
                                    y: 3px;
                                    text: "→";
                                    font-size: 14px;
                                    color: step < root.current_page ? #2d9b58 : #b9c1cb;
                                }

                                Rectangle {
                                    width: 14px;
                                    height: 16px;
                                    background: transparent;
                                    Rectangle {
                                        y: 3px;
                                        width: 14px;
                                        height: 14px;
                                        border-radius: 7px;
                                        border-width: 2px;
                                        border-color:
                                            step < root.current_page ? #2d9b58 :
                                            step == root.current_page ? #c88300 :
                                            #b9c1cb;
                                        background:
                                            step < root.current_page ? #2d9b58 :
                                            step == root.current_page ? #f3b343 :
                                            #ffffff;
                                    }
                                }

                                Text {
                                    text:
                                        step == 1 ? "Bienvenue" :
                                        step == 2 ? "Sources" :
                                        step == 3 ? "DKMS" :
                                        step == 4 ? "Paquets" :
                                        step == 5 ? "Dry-run" :
                                        "Reboot";
                                    font-size: 14px;
                                    color:
                                        step < root.current_page ? #2d9b58 :
                                        step == root.current_page ? #1f2a35 :
                                        #7b8794;
                                }
                            }
                        }
                        Rectangle { vertical-stretch: 1; background: transparent; }
                    }

                    Rectangle { horizontal-stretch: 1; background: transparent; }

                    Rectangle {
                        width: 140px;
                        background: transparent;
                        Button {
                            x: parent.width - self.width;
                            y: (parent.height - self.height) / 2;
                            width: 124px;
                            height: 40px;
                            text: root.current_page == 7 ? "Fermer" : root.current_page == 6 ? "Redemarrer" : "Suivant";
                            enabled: root.current_page == 7 || !root.action_in_progress;
                            clicked => {
                                if (root.current_page == 7) {
                                    root.close_app();
                                } else if (root.current_page == 6) {
                                    root.request_reboot();
                                } else {
                                    if (root.current_page == 1) {
                                        root.check_new_release();
                                    } else if (root.current_page == 2) {
                                        root.validate_sources();
                                    } else if (root.current_page == 3) {
                                        root.run_dkms_step();
                                    } else if (root.current_page == 4) {
                                        root.run_download_step();
                                    } else if (root.current_page == 5) {
                                        root.run_dry_run_upgrade();
                                    } else {
                                        root.go_next();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
