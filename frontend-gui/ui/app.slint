import { Button, CheckBox, TextEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    in-out property <int> current_page: 1;
    in-out property <string> header_status: "Assistant pret";
    in-out property <string> logs_text: "[info] Demarrage de l'assistant.";

    in-out property <bool> third_party_1_enabled: false;
    in-out property <bool> third_party_2_enabled: false;
    in-out property <bool> third_party_3_enabled: false;
    in-out property <string> third_party_1_name: "";
    in-out property <string> third_party_2_name: "";
    in-out property <string> third_party_3_name: "";
    in-out property <bool> third_party_1_visible: false;
    in-out property <bool> third_party_2_visible: false;
    in-out property <bool> third_party_3_visible: false;

    callback go_next();
    callback go_prev();
    callback validate_sources();
    callback check_new_release();
    callback run_download_step();
    callback run_dry_run_upgrade();
    callback request_reboot();
    callback close_app();
    public function scroll_logs_to_end(offset: int) {
        logs_edit.set-selection-offsets(offset, offset);
    }

    width: 960px;
    height: 620px;
    title: "Debian Upgrade Assistant";

    Rectangle {
        background: #f2f3f5;

        VerticalLayout {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            spacing: 12px;
            padding: 16px;

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 64px;

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "Debian Upgrade - Page " + root.current_page;
                        font-size: 20px;
                        color: #1b1e23;
                        vertical-alignment: center;
                    }

                    Rectangle { }

                    Text {
                        text: "Etat: " + root.header_status;
                        color: #4f5b66;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 300px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;

                    Text {
                        text: root.current_page == 1 ? "Bienvenue" :
                              root.current_page == 2 ? "Sources APT et depots tiers" :
                              root.current_page == 3 ? "Preparation des paquets" :
                              root.current_page == 4 ? "Test de mise a niveau (dry-run)" :
                              root.current_page == 5 ? "Mise a niveau finale" :
                              "Aucune mise a niveau disponible";
                        font-size: 22px;
                        color: #1b1e23;
                        vertical-stretch: 0;
                    }

                    Text {
                        text: root.current_page == 1
                            ? "Cet assistant vous guide pour preparer une mise a niveau majeure Debian de maniere controlee. Vous allez verifier les sources APT, gerer les depots tiers, preparer les paquets, tester la procedure puis finaliser au redemarrage."
                            : root.current_page == 2
                            ? "Par securite, tous les depots tiers sont desactives par defaut. Vous pouvez les re-activer manuellement si necessaire."
                            : root.current_page == 3
                            ? "Cette etape va nettoyer le cache APT et telecharger les paquets necessaires. Cliquez sur Suivant pour declencher."
                            : root.current_page == 4
                            ? "Un test de mise a niveau va etre execute en mode simulation pour verifier le deroulement."
                            : root.current_page == 5
                            ? "En cliquant sur Redemarrer, le PC redemarrera et la mise a niveau hors-ligne sera effectuee."
                            : "Le processus s'arrete ici: aucune nouvelle version majeure Debian n'est disponible pour ce systeme.";
                        wrap: word-wrap;
                        color: #2f3a45;
                        vertical-stretch: 0;
                    }

                    Text {
                        visible: root.current_page == 5 || root.current_page == 6;
                        text: "La procedure doit etre non interactive (DEBIAN_FRONTEND=noninteractive) avec choix par defaut pour eviter les blocages de questions APT.";
                        wrap: word-wrap;
                        color: #2f3a45;
                        vertical-stretch: 0;
                    }

                    Rectangle {
                        visible: root.current_page == 2;
                        background: #f8f9fb;
                        border-color: #e3e7ee;
                        border-width: 1px;
                        border-radius: 6px;
                        padding: 10px;
                        vertical-stretch: 0;
                        VerticalLayout {
                            spacing: 6px;
                            CheckBox {
                                visible: root.third_party_1_visible;
                                text: "Depot tiers: " + root.third_party_1_name;
                                checked <=> root.third_party_1_enabled;
                                vertical-stretch: 0;
                            }
                            CheckBox {
                                visible: root.third_party_2_visible;
                                text: "Depot tiers: " + root.third_party_2_name;
                                checked <=> root.third_party_2_enabled;
                                vertical-stretch: 0;
                            }
                            CheckBox {
                                visible: root.third_party_3_visible;
                                text: "Depot tiers: " + root.third_party_3_name;
                                checked <=> root.third_party_3_enabled;
                                vertical-stretch: 0;
                            }
                        }
                    }

                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 120px;

                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;

                    Text {
                        text: "Logs";
                        font-size: 18px;
                        color: #1b1e23;
                    }

                    logs_edit := TextEdit {
                        vertical-stretch: 1;
                        text: root.logs_text;
                        read-only: true;
                        wrap: word-wrap;
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                border-color: #d8dbe0;
                border-width: 1px;
                border-radius: 8px;
                height: 74px;

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Button {
                        text: "Precedent";
                        enabled: root.current_page > 1 && root.current_page < 6;
                        horizontal-stretch: 0;
                        clicked => { root.go_prev(); }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;
                    }

                    Button {
                        text: root.current_page == 6 ? "Fermer" : root.current_page == 5 ? "Redemarrer" : "Suivant";
                        horizontal-stretch: 0;
                        clicked => {
                            if (root.current_page == 6) {
                                root.close_app();
                            } else if (root.current_page == 5) {
                                root.request_reboot();
                            } else {
                                if (root.current_page == 1) {
                                    root.check_new_release();
                                } else if (root.current_page == 2) {
                                    root.validate_sources();
                                } else if (root.current_page == 3) {
                                    root.run_download_step();
                                } else if (root.current_page == 4) {
                                    root.run_dry_run_upgrade();
                                } else {
                                    root.go_next();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
